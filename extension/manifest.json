{
  "manifest_version": 3,
  "name": "Teams Extractor",
  "version": "0.1.0",
  "description": "Extract MS Teams conversations to Markdown files on your WSL filesystem.",

  "host_permissions": [
    "https://teams.microsoft.com/*"
  ],

  "permissions": [
    "storage",
    "nativeMessaging"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams Extractor"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
